generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  name           String
  password       String
  role           Role            @default(USER)
  lastLogin      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  bibleBookmarks BibleBookmark[]
  bibleNotes     BibleNote[]
  userPreference UserPreference?
  userProgress   UserProgress[]

  @@map("users")
}

model UserProgress {
  id        Int       @id @default(autoincrement())
  theme     String
  lessons   String?   @default("[]")
  startedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "user_progress_userId_fkey")
  @@map("user_progress")
}

model BibleBookmark {
  id                Int      @id @default(autoincrement())
  title             String?
  color             String?  @default("blue")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  userId            Int
  bookOrderIndex    Int
  versionOrderIndex Int
  chapter           Int
  verse             Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, versionOrderIndex, bookOrderIndex, chapter, verse])
  @@index([bookOrderIndex], map: "bible_bookmarks_bookOrderIndex_idx")
  @@index([versionOrderIndex], map: "bible_bookmarks_versionOrderIndex_idx")
  @@map("bible_bookmarks")
}

model BibleNote {
  id                Int      @id @default(autoincrement())
  title             String?
  content           String
  isPrivate         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  userId            Int
  bookOrderIndex    Int
  versionOrderIndex Int
  chapter           Int
  verse             Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookOrderIndex], map: "bible_notes_bookOrderIndex_idx")
  @@index([userId], map: "bible_notes_userId_fkey")
  @@index([versionOrderIndex], map: "bible_notes_versionOrderIndex_idx")
  @@map("bible_notes")
}

model UserPreference {
  id                       Int      @id @default(autoincrement())
  defaultVersionOrderIndex Int?
  notesPerVersion          Boolean  @default(false)
  bookmarksPerVersion      Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  userId                   Int      @unique
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([defaultVersionOrderIndex], map: "user_preferences_defaultVersionOrderIndex_idx")
  @@map("user_preferences")
}

enum Role {
  USER
  ADMIN
}
