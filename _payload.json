[{"data":1,"prerenderedAt":444},["ShallowReactive",2],{"/":3,"posts":161},{"id":4,"title":5,"body":6,"cta":125,"description":7,"extension":128,"hero":129,"meta":133,"mission":134,"navigation":141,"path":142,"seo":143,"stem":144,"teachings":145,"testimonials":154,"__hash__":160},"index/0.index.yml","Théologie pour Tous - Formation théologique en ligne",{"title":5,"description":7,"hero":8,"mission":23,"teachings":48,"testimonials":89,"cta":111,"seo":121},"Formation théologique accessible à tous, fondée sur les Écritures. Approfondissez votre connaissance de Dieu avec nos enseignements structurés.",{"badge":9,"title":12,"titleHighlight":13,"subtitle":14,"primaryCta":15,"secondaryCta":19},{"icon":10,"text":11},"i-lucide-cross","Formation théologique en ligne","Approfondissez votre","connaissance de Dieu","Une formation théologique accessible à tous, fondée sur les Écritures et guidée par l'Esprit Saint. Découvrez les richesses de la Parole de Dieu dans un parcours structuré et inspirant.",{"text":16,"icon":17,"link":18},"Commencer le parcours","i-lucide-book-open","/enseignements",{"text":20,"icon":21,"link":22},"En savoir plus","i-lucide-play-circle","/about",{"badge":24,"title":27,"subtitle":28,"pillars":29,"verse":44},{"icon":25,"text":26},"i-lucide-heart","Notre Mission","Équiper les saints pour l'œuvre du ministère","Notre passion est de rendre la théologie accessible à tous les chrétiens, afin qu'ils puissent grandir dans la connaissance de Dieu et servir efficacement dans Son royaume.",[30,34,39],{"title":31,"icon":17,"color":32,"description":33},"Enseignement Biblique","blue","Des cours fondés sur l'autorité des Écritures, enseignés avec fidélité et clarté pour nourrir votre âme et fortifier votre foi.",{"title":35,"icon":36,"color":37,"description":38},"Communauté","i-lucide-users","green","Rejoignez une communauté de croyants passionnés par l'étude de la Parole, où l'encouragement mutuel et la croissance spirituelle sont prioritaires.",{"title":40,"icon":41,"color":42,"description":43},"Formation Pratique","i-lucide-compass","purple","Une approche pratique de la théologie qui vous équipe pour le ministère et vous aide à appliquer la vérité biblique dans votre vie quotidienne.",{"text":45,"reference":46,"commentary":47},"Étudie-toi à te présenter devant Dieu comme un homme éprouvé","2 Timothée 2:15","Notre désir est de vous accompagner dans cette noble quête de connaissance biblique, pour que vous deveniez des ouvriers qui n'ont point à rougir.",{"badge":49,"title":52,"subtitle":53,"courses":54,"allCoursesCard":85},{"icon":50,"text":51},"i-lucide-graduation-cap","Nos Enseignements","Parcours de Formation Théologique","Explorez les grandes doctrines de la foi chrétienne à travers nos parcours structurés et approfondissez votre compréhension des vérités bibliques fondamentales.",[55,61,67,73,79],{"title":56,"name":57,"image":58,"description":59,"link":60},"Théologie Propre","theologie-propre","/images/themes/theologie-propre.jpg","Découvrez qui est Dieu : Ses attributs, Sa nature trinitaire, et Sa révélation à travers les Écritures.","/enseignements/theologie-propre",{"title":62,"name":63,"image":64,"description":65,"link":66},"Christologie","christologie","/images/themes/christologie.jpg","Étudiez la personne et l'œuvre de Jésus-Christ, vrai Dieu et vrai homme, notre Sauveur.","/enseignements/christologie",{"title":68,"name":69,"image":70,"description":71,"link":72},"Pneumatologie","pneumatologie","/images/themes/pneumatologie.jpg","Apprenez sur la personne et l'œuvre du Saint-Esprit dans la vie du croyant et de l'Église.","/enseignements/pneumatologie",{"title":74,"name":75,"image":76,"description":77,"link":78},"Sotériologie","soteriologie","/images/themes/soteriologie.jpg","Explorez la doctrine du salut par grâce, l'œuvre rédemptrice du Christ pour nous.","/enseignements/soteriologie",{"title":80,"name":81,"image":82,"description":83,"link":84},"Hamartiologie","hamartiologie","/images/themes/hamartiologie.jpg","Comprenez la nature du péché et ses conséquences, pour mieux apprécier la grâce de Dieu.","/enseignements/hamartiologie",{"title":86,"description":87,"cta":88,"link":18},"Voir tous les parcours","Découvrez l'ensemble de nos formations théologiques et choisissez votre parcours d'apprentissage.","Parcourir tout",{"badge":90,"title":93,"subtitle":94,"reviews":95},{"icon":91,"text":92},"i-lucide-quote","Témoignages","Ce que disent nos étudiants","Découvrez comment la formation théologique a transformé la vie et le ministère de ceux qui nous ont fait confiance.",[96,101,106],{"name":97,"role":98,"image":99,"quote":100},"Marie Dubois","Pasteure adjointe","https://placehold.co/1200x630?text=Marie+Dubois","Cette formation m'a permis d'approfondir ma compréhension des Écritures d'une manière que je n'aurais jamais imaginée. Les enseignements sont riches, accessibles et profondément ancrés dans la Parole de Dieu.",{"name":102,"role":103,"image":104,"quote":105},"Pierre Martin","Enseignant biblique","https://placehold.co/1200x630?text=Pierre+Martin","J'ai particulièrement apprécié l'approche systématique et la qualité pédagogique. Ces études m'ont équipé pour enseigner avec plus de confiance et de précision dans mon ministère local.",{"name":107,"role":108,"image":109,"quote":110},"Sarah Leroux","Responsable jeunesse","https://placehold.co/1200x630?text=Sarah+Leroux","Une formation qui allie profondeur théologique et application pratique. Mon ministère auprès des jeunes s'en trouve enrichi et ma foi fortifiée. Je recommande vivement ce parcours.",{"title":112,"titleHighlight":113,"subtitle":114,"primaryButton":115,"secondaryButton":118,"benefits":120},"Prêt à commencer votre","parcours théologique ?","Rejoignez des milliers de chrétiens qui approfondissent leur foi et se préparent à servir le Seigneur avec excellence.",{"text":116,"icon":117,"link":18},"Commencer maintenant","i-lucide-rocket",{"text":20,"icon":119,"link":22},"i-lucide-info","✨ Accès immédiat • 📱 Compatible tous appare