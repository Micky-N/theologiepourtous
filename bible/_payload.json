43,348,352,356,360,364,368],{"orderIndexId":6,"code":344,"name":345,"language":346,"year":347},"LSG","Louis Segond 1910","fr",1910,{"orderIndexId":13,"code":349,"name":350,"language":346,"year":351},"S21","Segond 21",2007,{"orderIndexId":18,"code":353,"name":354,"language":346,"year":355},"BDS","Bible du Semeur",1999,{"orderIndexId":23,"code":357,"name":358,"language":346,"year":359},"MAB","Martin 1744",1744,{"orderIndexId":28,"code":361,"name":362,"language":346,"year":363},"DBY","Darby Bible",1885,{"orderIndexId":33,"code":365,"name":366,"language":346,"year":367},"OST","Ostervald 1996",1996,{"orderIndexId":38,"code":369,"name":370,"language":371,"year":372},"KJV","King James Version","en",1611,{"book":374,"version":375,"chapter":6,"verses":376,"navigation":470},{"code":7,"name":8,"testament":9},{"code":344,"name":345},[377,380,383,386,389,392,395,398,401,404,407,410,413,416,419,422,425,428,431,434,437,440,443,446,449,452,455,458,461,464,467],{"id":378,"chapter":6,"verse":6,"text":379,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:1:LSG","Au commencement, Dieu créa les cieux et la terre.",{"id":381,"chapter":6,"verse":13,"text":382,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:2:LSG","La terre était informe et vide: il y avait des ténèbres à la surface de l'abîme, et l'esprit de Dieu se mouvait au-dessus des eaux.",{"id":384,"chapter":6,"verse":18,"text":385,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:3:LSG","Dieu dit: Que la lumière soit! Et la lumière fut.",{"id":387,"chapter":6,"verse":23,"text":388,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:4:LSG","Dieu vit que la lumière était bonne; et Dieu sépara la lumière d'avec les ténèbres.",{"id":390,"chapter":6,"verse":28,"text":391,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:5:LSG","Dieu appela la lumière jour, et il appela les ténèbres nuit. Ainsi, il y eut un soir, et il y eut un matin: ce fut le premier jour.",{"id":393,"chapter":6,"verse":33,"text":394,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:6:LSG","Dieu dit: Qu'il y ait une étendue entre les eaux, et qu'elle sépare les eaux d'avec les eaux.",{"id":396,"chapter":6,"verse":38,"text":397,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:7:LSG","Et Dieu fit l'étendue, et il sépara les eaux qui sont au-dessous de l'étendue d'avec les eaux qui sont au-dessus de l'étendue. Et cela fut ainsi.",{"id":399,"chapter":6,"verse":43,"text":400,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:8:LSG","Dieu appela l'étendue ciel. Ainsi, il y eut un soir, et il y eut un matin: ce fut le second jour.",{"id":402,"chapter":6,"verse":47,"text":403,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:9:LSG","Dieu dit: Que les eaux qui sont au-dessous du ciel se rassemblent en un seul lieu, et que le sec paraisse. Et cela fut ainsi.",{"id":405,"chapter":6,"verse":52,"text":406,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:10:LSG","Dieu appela le sec terre, et il appela l'amas des eaux mers. Dieu vit que cela était bon.",{"id":408,"chapter":6,"verse":56,"text":409,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:11:LSG","Puis Dieu dit: Que la terre produise de la verdure, de l'herbe portant de la semence, des arbres fruitiers donnant du fruit selon leur espèce et ayant en eux leur semence sur la terre. Et cela fut ainsi.",{"id":411,"chapter":6,"verse":61,"text":412,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:12:LSG","La terre produisit de la verdure, de l'herbe portant de la semence selon son espèce, et des arbres donnant du fruit et ayant en eux leur semence selon leur espèce. Dieu vit que cela était bon.",{"id":414,"chapter":6,"verse":66,"text":415,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:13:LSG","Ainsi, il y eut un soir, et il y eut un matin: ce fut le troisième jour.",{"id":417,"chapter":6,"verse":71,"text":418,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:14:LSG","Dieu dit: Qu'il y ait des luminaires dans l'étendue du ciel, pour séparer le jour d'avec la nuit; que ce soient des signes pour marquer les époques, les jours et les années;",{"id":420,"chapter":6,"verse":75,"text":421,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:15:LSG","et qu'ils servent de luminaires dans l'étendue du ciel, pour éclairer la terre. Et cela fut ainsi.",{"id":423,"chapter":6,"verse":79,"text":424,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:16:LSG","Dieu fit les deux grands luminaires, le plus grand luminaire pour présider au jour, et le plus petit luminaire pour présider à la nuit; il fit aussi les étoiles.",{"id":426,"chapter":6,"verse":83,"text":427,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:17:LSG","Dieu les plaça dans l'étendue du ciel, pour éclairer la terre,",{"id":429,"chapter":6,"verse":87,"text":430,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:18:LSG","pour présider au jour et à la nuit, et pour séparer la lumière d'avec les ténèbres. Dieu vit que cela était bon.",{"id":432,"chapter":6,"verse":92,"text":433,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:19:LSG","Ainsi, il y eut un soir, et il y eut un matin: ce fut le quatrième jour.",{"id":435,"chapter":6,"verse":97,"text":436,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:20:LSG","Dieu dit: Que les eaux produisent en abondance des animaux vivants, et que des oiseaux volent sur la terre vers l'étendue du ciel.",{"id":438,"chapter":6,"verse":41,"text":439,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:21:LSG","Dieu créa les grands poissons et tous les animaux vivants qui se meuvent, et que les eaux produisirent en abondance selon leur espèce; il créa aussi tout oiseau ailé selon son espèce. Dieu vit que cela était bon.",{"id":441,"chapter":6,"verse":59,"text":442,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:22:LSG","Dieu les bénit, en disant: Soyez féconds, multipliez, et remplissez les eaux des mers; et que les oiseaux multiplient sur la terre.",{"id":444,"chapter":6,"verse":107,"text":445,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:23:LSG","Ainsi, il y eut un soir, et il y eut un matin: ce fut le cinquième jour.",{"id":447,"chapter":6,"verse":36,"text":448,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:24:LSG","Dieu dit: Que la terre produise des animaux vivants selon leur espèce, du bétail, des reptiles et des animaux terrestres, selon leur espèce. Et cela fut ainsi.",{"id":450,"chapter":6,"verse":64,"text":451,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:25:LSG","Dieu fit les animaux de la terre selon leur espèce, le bétail selon son espèce, et tous les reptiles de la terre selon leur espèce. Dieu vit que cela était bon.",{"id":453,"chapter":6,"verse":119,"text":454,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:26:LSG","Puis Dieu dit: Faisons l'homme à notre image, selon notre ressemblance, et qu'il domine sur les poissons de la mer, sur les oiseaux du ciel, sur le bétail, sur toute la terre, et sur tous les reptiles qui rampent sur la terre.",{"id":456,"chapter":6,"verse":21,"text":457,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:27:LSG","Dieu créa l'homme à son image, il le créa à l'image de Dieu, il créa l'homme et la femme.",{"id":459,"chapter":6,"verse":127,"text":460,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:28:LSG","Dieu les bénit, et Dieu leur dit: Soyez féconds, multipliez, remplissez la terre, et l'assujettissez; et dominez sur les poissons de la mer, sur les oiseaux du ciel, et sur tout animal qui se meut sur la terre.",{"id":462,"chapter":6,"verse":69,"text":463,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:29:LSG","Et Dieu dit: Voici, je vous donne toute herbe portant de la semence et qui est à la surface de toute la terre, et tout arbre ayant en lui du fruit d'arbre et portant de la semence: ce sera votre nourriture.",{"id":465,"chapter":6,"verse":134,"text":466,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:30:LSG","Et à tout animal de la terre, à tout oiseau du ciel, et à tout ce qui se meut sur la terre, ayant en soi un souffle de vie, je donne toute herbe verte pour nourriture. Et cela fut ainsi.",{"id":468,"chapter":6,"verse":50,"text":469,"createdAt":11,"versionId":344,"bookId":7},"GEN:1:31:LSG","Dieu vit tout ce qu'il avait fait et voici, cela était très bon. Ainsi, il y eut un soir, et il y eut un matin: ce fut le sixième jour.",{"previousChapter":471,"nextChapter":13,"totalChapters":10},null,1774453265511]